{
  "name": "telegram-bot",
  "version": "1.0.0",
  "type": "module",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "postinstall": "node -e \"try{if(require('fs').existsSync('./patch-bot.cjs') && require('fs').existsSync('./bot.js')){require('child_process').execSync('node patch-bot.cjs',{stdio:'inherit'})}}catch(e){console.error('postinstall patch err:',e.message)}\""
  },
  "dependencies": {
    "telegraf": "^4.16.3",
    "express": "^4.18.2"
  }
}
